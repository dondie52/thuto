# Optional: HTTPS URL returning JSON (array of universities, or `{ "universities": [...] }`).
# Objects are merged into bundled `public/data/universities.json` by matching `id`.
# Must send CORS headers allowing your Thuto origin (e.g. Access-Control-Allow-Origin).
# VITE_UNIVERSITIES_REMOTE_URL=https://your-cdn.example.com/thuto/universities.json

# Optional: future AI provider flags. These are not secret keys.
# Real provider keys must live only on a server or serverless function.
VITE_AI_ENABLED=false
VITE_AI_PROVIDER=

# Optional: Supabase project for anonymous community admission submissions (see pillar2_community_data.md).
# If unset, community share/stats UI is hidden.
# Apply scripts/supabase-rls-policies.sql in the Supabase SQL editor, then test /share with the anon key only.
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=your_anon_key
